error ValueErr {
    tooSmall,
    tooBig,
}
error OtherErr {
    randomErr,
    anotherErr,
}

fn failable(val: int) -> bool!ValueErr|OtherErr {
    if val < 4 {
        fail .tooSmall
    } else if val < 10 {
        return true
    } else if val < 20 {
        fail .anotherErr
    } else if val > 200 {
        fail .tooBig
    }

    fail .randomErr
}

fn testFail(value: int) {
    print failable(value) trap match e is {
        ValueErr {
            .tooSmall => 1
            .tooBig => 100
        }
        OtherErr => -999
    }
}

fn main() {
    testFail(2)
    testFail(8)
    testFail(12)
    testFail(220)
    testFail(100)

    print failable(15) trap e {
        print e
        break 88
    }
}


