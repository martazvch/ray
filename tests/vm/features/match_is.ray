fn getValue() -> int|float {
    return 5
}

fn main() {
    var a: int|float = 8.3

    match a is {
        int => print a + 1
        float => print "float"
    }

    let b = match a is {
        int => 1
        else => 5
    }
    print b

    let trash = true
    match a is {
        float {
            1.2 => print "first"
            4.5..10.0 => print "second"
            else => print "non"
        }
        int => print "int"
    }

    match getValue() @v is {
        float => print v + 8.5
        int => print 1 + v
    }
}

