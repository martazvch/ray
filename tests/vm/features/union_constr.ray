enum Dir { north, south }

union Bar {
    aa: str,
    bb: []bool,
}

union Foo {
    a: int,
    b: float,
    c,
    d: Dir,
    e: Bar,
}

fn main() {
    var foo = Foo.a(5)
    print foo
    print foo.a
    foo = Foo.b(1.2)
    print foo
    print foo.b
    foo = Foo.c
    print foo
    foo = Foo.d(Dir.south)
    print foo
    print foo.d

    foo = .a(5)
    print foo
    print foo.a
    foo = .b(1.2)
    print foo
    print foo.b
    foo = .c
    print foo
    foo = .d(.south)
    print foo
    print foo.d

    foo = .e(.bb([true, false]))
    print foo.e.bb
}

