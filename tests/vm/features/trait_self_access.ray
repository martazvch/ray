trait Foo {
    fn speak(self, a: int)
    fn speak2(self, a: int) {
        print a == 1
    }
}

struct Bar {
    value: bool,

    impl Foo {
        fn speak(self, a: int) {
            print self.value
            print "Bar " + str(a)
        }
    }
}

struct Baz {
    value=6,

    impl Foo {
        fn speak(self, a=2) {
            print self.value
            print "Baz " + str(a)
        }
    }
}

fn f(value: Foo) {
    value.speak(2)
}

fn main() {
    let bar = Bar{value: true}
    bar.speak(1)
    f(bar)

    let baz = Baz{}
    baz.speak(8)
    f(baz)
}

