trait Foo {
    fn speak(self, a: int)
}

struct Bar {
    impl Foo {
        fn speak(self, a=1) {
            print "Bar " + str(a)
        }
    }
}

struct Baz {
    impl Foo {
        fn speak(self, a=3) {
            print "Baz " + str(a)
        }
    }
}

fn f(value: Foo) {
    value.speak(2)
}

fn main() {
    let bar = Bar{}
    bar.speak()
    f(bar)

    let baz = Baz{}
    baz.speak()
    f(baz)
}

