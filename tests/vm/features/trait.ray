trait Foo {
    fn speak() {
        print "hello"
    }
    fn speakNoBody()

    fn withDefault(a: int) -> bool {
        return a == 1
    }
    fn withDefaultNoBody(a: int) -> bool

    fn method0(self) { print "method0" }

    fn method1(self) {
        self.method0()
    }
}

struct Bar {
    impl Foo {
        fn speakNoBody() { print "bye" }
        fn withDefault(a=9) -> bool {
            return a == 9
        }
        fn withDefaultNoBody(a=2) -> bool { return a == 2 }
    }
}

struct Baz {
    impl Foo {
        fn speakNoBody() { print "adios" }
        fn withDefaultNoBody(a=5) -> bool { return a == 5 }
    }
}

fn main() {
    Bar.speak()
    Baz.speak()
    Bar.speakNoBody()
    Baz.speakNoBody()

    print Bar.withDefault()
    print Baz.withDefault(4)
    print Bar.withDefaultNoBody(1)
    print Baz.withDefaultNoBody(2)
    print Bar.withDefaultNoBody()
    print Baz.withDefaultNoBody()

    let bar = Bar{}
    bar.method1()
}


