error ValueErr {
    tooSmall,
    tooBig,
}

fn failable(val: int) -> bool!ValueErr {
    if val < 10 {
        return true
    }
    fail .tooSmall
}

fn main() {
    print failable(15) trap e {
        print e
        break 88
    }
    print failable(15) trap e {
        return
    }
    print failable(15) trap match e {
        .tooSmall => 1
        else => 4
    }
    failable(15) trap match e {
        .tooSmall => print 1
        else => print 4
    }
}

